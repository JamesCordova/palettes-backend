# Supabase Session Pooler URI (Project -> Connect -> URI -> Session pooler).
# Uses IPv4 and supports prepared statements, unlike the direct connection
# (IPv6-only) or the transaction pooler (no prepared statement support).
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres
ENVIRONMENT=development

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=<random-secret>
ACCESS_TOKEN_EXPIRE_MINUTES=60
